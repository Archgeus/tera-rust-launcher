{
  "build": {
    "devPath": "../src",
    "distDir": "../src",
    "withGlobalTauri": true
  },

  "package": {
    "productName": "TeraLauncher",
    "version": "1.0.4"
  },

  "tauri": {
    "allowlist": {
      "all": true,
      "shell": {
        "all": true,
        "open": true
      }
    },
    "windows": [
      {
        "title": "Tera Launcher",
        "width": 1282,
        "height": 759,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "center": true,
        "contentProtected": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.teralib.dev",
      "icon": [
        "icons/tera_server.png",
        "icons/tera_server.ico"
      ],
      "copyright": "© 2026                                 TERA Private. All rights reserved.",
      "shortDescription": "TERA Online Private Server Launcher",
      "longDescription": "Custom launcher for TERA Online private server."
    }
  }
}